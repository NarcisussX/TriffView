<Window x:Class="TriffView.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="TriffView"
        Icon="Assets/TriffView.ico"
        Width="1120"
        Height="780"
        MinWidth="860"
        MinHeight="600"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Background="{DynamicResource TriffToolsBackgroundBrush}"
        Topmost="True"
        ShowInTaskbar="True"
        Loaded="OnLoaded"
        Closed="OnClosed"
        StateChanged="OnStateChanged">
    <Window.Resources>
        <SolidColorBrush x:Key="TriffToolsBackgroundBrush" Color="#05070B" />
    </Window.Resources>
    <Grid Background="{StaticResource TriffToolsBackgroundBrush}">
        <wv2:WebView2 x:Name="AppWebView" Focusable="True" />
    </Grid>
</Window>
