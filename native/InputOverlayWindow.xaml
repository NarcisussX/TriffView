<Window x:Class="TriffView.InputOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TriffView Input"
        Icon="Assets/TriffView.ico"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ShowActivated="True"
        Loaded="OnLoaded"
        PreviewTextInput="OnPreviewTextInput"
        PreviewKeyDown="OnPreviewKeyDown"
        PreviewMouseWheel="OnInputSurfaceMouseWheel">
    <Grid x:Name="InputSurface"
          Background="#01000000"
          Focusable="True"
          MouseDown="OnInputSurfaceMouseDown"
          MouseMove="OnInputSurfaceMouseMove"
          MouseUp="OnInputSurfaceMouseUp"
          MouseWheel="OnInputSurfaceMouseWheel" />
</Window>
